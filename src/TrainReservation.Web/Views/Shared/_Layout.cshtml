@{
    // Marks the current section in the navbar.
    string Active(string controller) =>
        string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), controller, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RailPlan</title>

    @* Bootstrap is served from wwwroot, not a CDN, so the app works with no network at all. *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom shadow-sm no-print">
    <div class="container">
        <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">🚆 RailPlan</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
                aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @Active("Bookings")" asp-controller="Bookings" asp-action="Index">Bookings</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @Active("Schedule")" asp-controller="Schedule" asp-action="Index">Schedule</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @Active("SpecialRequests")" asp-controller="SpecialRequests" asp-action="Index">Special requests</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @Active("Weekly")" asp-controller="Weekly" asp-action="Index">Weekly view</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @Active("Chat")" asp-controller="Chat" asp-action="Index">Predictions</a>
                </li>
            </ul>

            <a class="btn btn-primary" asp-controller="Bookings" asp-action="Create">+ New booking</a>
        </div>
    </div>
</nav>

<main class="container flex-grow-1 py-4">
    @* Flash messages set by the controllers before a redirect. *@
    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show no-print" role="alert">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show no-print" role="alert">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @RenderBody()
</main>

<footer class="border-top py-3 mt-auto bg-light no-print">
    <div class="container text-muted small">
        RailPlan — personal train reservation &amp; management tool.
        In-memory prototype; data resets when the app restarts.
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
